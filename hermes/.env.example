# Copy to hermes/.env and fill in values. Never commit the real file.
OPENROUTER_API_KEY=sk-or-v1-your-key
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_ALLOWED_USERS=123456789

# Optional: enable webhook mode instead of polling (requires a public HTTPS URL)
# TELEGRAM_WEBHOOK_URL=https://your-subdomain.trycloudflare.com/telegram
# TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# Used by the GitHub MCP server (also set in config.yaml)
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your_token
